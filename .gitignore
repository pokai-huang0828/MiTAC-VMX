# Ignore all dotfiles and dotfolders (personal IDE / tool / OS configs)
.*
# Keep .gitignore itself tracked
!.gitignore
# Keep .claude/ tracked (Claude Code config: launch.json, project settings, etc.)
!.claude/
!.claude/**

# Local firmware/update artifacts
image_update/*
EVO_image_update/*

# Keep update process documentation
!EVO_image_update/EVO image update process.md

# Python bytecode (build script side-effect)
__pycache__/
*.pyc
